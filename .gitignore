# ============================================================
# Smart Industrial Automation — .gitignore
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
wheels/
*.whl
MANIFEST

# ------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env/

# ------------------------------------------------------------
# Environment variable files (may contain SMTP credentials)
# ------------------------------------------------------------
.env
.env.*
*.env

# ------------------------------------------------------------
# Generated sensor data / CSV output
# ------------------------------------------------------------
*.csv
data/
output/
outputs/

# ------------------------------------------------------------
# Generated report files
# ------------------------------------------------------------
demo_report.html

# ------------------------------------------------------------
# ML model files (if saved in future)
# ------------------------------------------------------------
*.pkl
*.joblib
*.h5
*.pt
*.pth
models/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# IDEs — VS Code
# ------------------------------------------------------------
.vscode/
*.code-workspace

# ------------------------------------------------------------
# IDEs — PyCharm / IntelliJ
# ------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr

# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ------------------------------------------------------------
# Jupyter Notebooks (checkpoints)
# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ------------------------------------------------------------
# Coverage / testing
# ------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
.tox/